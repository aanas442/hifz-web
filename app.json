{
  "expo": {
    "name": "হিফজ কম্পেনিয়ন",
    "slug": "hifz-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "hifzcompanion",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1B4332"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hifzcompanion.app"
    },
    "android": {
      "package": "com.hifzcompanion.app",
      "adaptiveIcon": {
        "backgroundColor": "#1B4332"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9231ce6d-9a66-4512-8ae8-db714a80836a"
      }
    },
    "owner": "anas442"
  }
}
